# OpenAI — Responses API
OPENAI_API_KEY=sk-...
OPENAI_DEFAULT_PROVIDER=openai
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4
OPENAI_REASONING_EFFORT=medium
OPENAI_TEMPERATURE=0
OPENAI_TIMEOUT_SECONDS=120
# Anthropic — Messages API
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_API_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_TIMEOUT_SECONDS=120
# Optional. Leave unset until the active model's pricing is confirmed.
# When unset, Pattern Pilot reports cost as unavailable instead of $0.
# OPENAI_INPUT_COST_PER_1M=2.50
# OPENAI_OUTPUT_COST_PER_1M=10.00

# Database
DATABASE_URL=postgresql+asyncpg://pp:pp_dev@localhost:5437/pattern_pilot

# QC Loop
PP_MAX_ROUNDS=3
PP_DEFAULT_REVIEW_PROFILE=standard

# Logging
PP_LOG_LEVEL=INFO
